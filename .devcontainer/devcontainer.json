{
  "name": "Certamen 3 - Python",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ],
      "settings": {
        // Editor general
        "editor.fontSize": 14,
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.formatOnSave": false,

        // Deshabilitar GitHub Copilot completamente
        "github.copilot.enable": {
          "*": false
        },
        "github.copilot.editor.enableAutoCompletions": false,
        "github.copilot.chat.enabled": false,

        // Deshabilitar IntelliSense con IA y sugerencias automáticas
        "editor.inlineSuggest.enabled": false,
        "editor.suggestOnTriggerCharacters": false,
        "editor.quickSuggestions": {
          "other": false,
          "comments": false,
          "strings": false
        },
        "editor.parameterHints.enabled": false,
        "editor.wordBasedSuggestions": "off",

        // Deshabilitar features experimentales de IA de VS Code
        "workbench.experimental.aiAssist.enabled": false,
        "chat.commandCenter.enabled": false
      }
    }
  },

  // Bloquear instalación de extensiones de IA
  "extensions": {
    "denied": [
      "GitHub.copilot",
      "GitHub.copilot-chat",
      "GitHub.copilot-labs",
      "TabNine.tabnine-vscode",
      "Codeium.codeium",
      "AmazonWebServices.aws-toolkit-vscode"
    ]
  },

  "postCreateCommand": "echo '✅ Entorno listo. Python $(python --version)'"
}
